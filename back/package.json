{
    "name": "tap-for-good-back",
    "version": "0.1.0",
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "node --env-file=.env --import tsx src/server.ts",
        "build": "tsc",
        "start": "node --env-file=.env dist/src/server.js",
        "db:generate": "prisma generate",
        "db:migrate": "prisma migrate dev",
        "db:seed": "prisma db seed",
        "format": "prettier --ignore-path ../.prettierignore --write .",
        "format:check": "prettier --ignore-path ../.prettierignore --check .",
        "lint": "tsc --noEmit",
        "test": "pnpm run lint"
    },
    "dependencies": {
        "@prisma/client": "^6.10.1",
        "mastercard-oauth1-signer": "^1.2.0",
        "pg": "^8.16.3",
        "zod": "^3.25.67"
    },
    "devDependencies": {
        "@types/node": "^24.0.10",
        "prettier": "^3.8.1",
        "prisma": "^6.10.1",
        "tsx": "^4.20.3",
        "typescript": "^5.8.3"
    },
    "prisma": {
        "seed": "node --env-file=.env --import tsx prisma/seed.ts"
    }
}
